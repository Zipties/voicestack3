# VoiceStack3 Environment Configuration
#
# Copy this file to .env and edit for your setup.
# Most defaults work out of the box — just set API_TOKEN.

# ── Platform ──────────────────────────────────────────────────────────────
# NVIDIA GPU: WORKER_TAG=latest, WHISPER_COMPUTE_TYPE=float16
# CPU (Mac/Linux): WORKER_TAG=cpu, WHISPER_COMPUTE_TYPE=int8
WORKER_TAG=cpu
WHISPER_COMPUTE_TYPE=int8

# API authentication token (change this!)
API_TOKEN=changeme

# ── Database (defaults work with bundled PostgreSQL) ──────────────────────
# POSTGRES_USER=voice
# POSTGRES_PASSWORD=voice
# POSTGRES_DB=voice
# DATABASE_URL=postgresql+psycopg://voice:voice@db:5432/voice

# ── Whisper ───────────────────────────────────────────────────────────────
# WHISPER_MODEL=large-v3
# WHISPER_BATCH_SIZE=16
# SPEAKER_MATCH_THRESHOLD=0.45

# ── Optional: OpenClaw AI agents ──────────────────────────────────────────
# Requires an OpenClaw gateway. Enable the openclaw compose profile:
#   docker compose --profile openclaw up -d
# OPENCLAW_GATEWAY_URL=wss://your-gateway.example.com
# OPENCLAW_GATEWAY_TOKEN=your-token-here

# ── Optional: Semantic search ─────────────────────────────────────────────
# QDRANT_URL=http://localhost:6333
# EMBED_URL=http://localhost:7997/embeddings
# EMBED_API_KEY=

# ── Optional: App base URL (for external access) ─────────────────────────
# APP_BASE_URL=http://localhost:3000
