# VoiceStack3 Environment Configuration
#
# The install script auto-detects your platform and sets these.
# To configure manually, copy this file to .env and edit.

# Platform: cuda (NVIDIA GPU) or cpu (macOS / no GPU)
PLATFORM=cuda

# API authentication token
API_TOKEN=changeme

# PostgreSQL
POSTGRES_USER=voice
POSTGRES_PASSWORD=voice
POSTGRES_DB=voice
DATABASE_URL=postgresql+psycopg://voice:voice@db:5432/voice

# Redis
REDIS_URL=redis://redis:6379/0

# WhisperX settings
WHISPER_MODEL=large-v2
WHISPER_COMPUTE_TYPE=float16
WHISPER_BATCH_SIZE=16

# Speaker matching threshold (0.0-1.0, lower = stricter matching)
SPEAKER_MATCH_THRESHOLD=0.3

# Optional: LLM for metadata generation (title/summary/tags)
# Configure via the Settings page in the UI.

# Optional: Qdrant semantic search (configure via Settings page)
# QDRANT_URL=http://localhost:6333
# EMBED_URL=http://localhost:7997/embeddings
# EMBED_API_KEY=

# App base URL (used in API responses for links)
# APP_BASE_URL=http://localhost:3000
